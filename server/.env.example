SOUNDCLOUD_CLIENT_ID=
YANDEX_TOKEN=

# Optional. Yandex geo-blocks anonymous catalog access (search/charts) from
# outside Russia with a 451 — if you're hitting that, point this at an
# HTTP/SOCKS proxy with a Russian exit IP, e.g. http://user:pass@host:port
YANDEX_PROXY_URL=

# Spotify Web API (Client Credentials flow).
# Create an app at https://developer.spotify.com/dashboard to get these.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
