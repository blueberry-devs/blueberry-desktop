{
  "name": "blueberry-desktop",
  "version": "1.201.0",
  "description": "Яндекс Музыка",
  "main": "./out/main/index.js",
  "author": "torusov",
  "license": "GPL-3.0",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "start": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.web.json",
    "build:server": "scripts\\build-server.bat",
    "dist:win": "npm run build:server && npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux",
    "dist:all": "npm run build && electron-builder -mwl",
    "release:win": "npm run build:server && npm run build && electron-builder --win --publish always"
  },
  "dependencies": {
    "@types/three": "^0.185.1",
    "@xhayper/discord-rpc": "^1.3.4",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.9",
    "hls.js": "^1.6.16",
    "motion": "^12.42.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.185.1"
  },
  "build": {
    "appId": "com.yandex.music.clone",
    "productName": "Yandex-Music",
    "icon": "resources/icon.png",
    "extraResources": [
      {
        "from": "server",
        "to": "server",
        "filter": [
          "**/*",
          "!**/__pycache__",
          "!**/.venv"
        ]
      },
      {
        "from": "resources/artists",
        "to": "artists"
      }
    ],
    "publish": {
      "provider": "github",
      "owner": "blueberry-devs",
      "repo": "blueberry-desktop"
    },
    "win": {
      "artifactName": "Yandex-Music-Setup.${version}.exe",
      "icon": "resources/icon.ico",
      "extraResources": [
        {
          "from": "build/packed-server",
          "to": "server"
        }
      ]
    },
    "linux": {
      "artifactName": "Yandex-Music-${version}.AppImage",
      "icon": "resources/icon.png",
      "extraResources": [
        {
          "from": "build/packed-server",
          "to": "server"
        }
      ]
    },
    "mac": {
      "target": [
        "zip"
      ],
      "artifactName": "Yandex-Music-${version}-${arch}.zip",
      "icon": "resources/icon-mac.png",
      "extraResources": [
        {
          "from": "build/packed-server",
          "to": "server"
        }
      ]
    }
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "electron": "^32.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
